@baseUrl = http://localhost:3000/api
@accessToken = MTUyNjk4MTEzMjMxNzYyMjM5Mw.ZvOrFVcvnkzDmYCYPWc5ekkmpFaOqA
@guildId = 1526984363240194169

### ========================================
### Discord - Get Invite URL
### ========================================

GET {{baseUrl}}/discord/invite

### ========================================
### Discord - OAuth Callback
### Copy the "code" parameter from Discord's redirect URL.
### Example:
### http://localhost:3000/api/discord/callback?code=XXXXXXXX
### ========================================

GET {{baseUrl}}/discord/callback?code=AUTHORIZATION_CODE_HERE

### ========================================
### Discord - Current User
### ========================================

GET {{baseUrl}}/discord/me
Authorization: Bearer {{accessToken}}

### ========================================
### Discord - User Guilds
### ========================================

GET {{baseUrl}}/discord/guilds
Authorization: Bearer {{accessToken}}

### ========================================
### Discord - Guild Channels
### ========================================

GET {{baseUrl}}/discord/guilds/{{guildId}}/channels
Authorization: Bearer {{accessToken}}